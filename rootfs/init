#!/bin/sh
# rootfs/init — k_K chat linuxAI 的 init 进程
# 由 busybox init 在 PID 1 执行,负责挂载伪文件系统、设置 console、启动 k_K 主程序
#
# 设计原则:
# 1. 失败也不 panic — 退到 busybox ash shell 让用户能调试
# 2. console UTF-8 + CJK 字体 — 中文显示
# 3. 启动 k_K 主程序 (PID 不固定,init 持续 supervise)

BUSYBOX=/bin/busybox
K_K_BIN=/usr/bin/k_K
K_K_CFG=/etc/k_K/config.txt

# 伪文件系统挂载
mount -t proc     proc     /proc     2>/dev/null
mount -t sysfs    sysfs    /sys      2>/dev/null
mount -t devtmpfs devtmpfs /dev      2>/dev/null
mount -t tmpfs    tmpfs    /run      2>/dev/null
mount -t tmpfs    tmpfs    /tmp      2>/dev/null

# 加载 k_K 需要的字符集 (UTF-8, GBK)
echo ">>> k_K chat linuxAI 启动中..."
echo ">>> 挂载基础文件系统完成"

# 设置 console 为 UTF-8 + CJK
if [ -w /sys/class/console/console ]; then
    echo 0 > /sys/class/console/console/active 2>/dev/null
fi
echo ">>> 设置 console locale (UTF-8 + CJK)"
export LANG=zh_CN.UTF-8
export LC_ALL=zh_CN.UTF-8
export TERM=linux

# 设置键盘布局 (US 即可,手写不需要键盘)
# loadkeys 在 BusyBox 中不可用,跳过
# loadkeys us 2>/dev/null || true

# 启动 k_K (自动重启)
if [ -x "$K_K_BIN" ]; then
    echo ">>> 启动 k_K 主程序 (路径: $K_K_BIN)..."
    (
        while true; do
            if [ -c /dev/tty1 ]; then
                setsid sh -c "$K_K_BIN < /dev/tty1 > /dev/tty1 2>&1"
            else
                setsid sh -c "$K_K_BIN < /dev/console > /dev/console 2>&1"
            fi
            echo ">>> k_K 退出,3 秒后重启..."
            sleep 3
        done
    ) &
else
    echo "!!! 错误: $K_K_BIN 不存在或不可执行"
    echo "!!! 启动 busybox shell 供调试"
fi

# PID 1 持续 supervise 主程序并提供 busybox shell
exec /bin/sh
